<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.c.infrastructure.dao.McpGatewayAuthDao">

    <resultMap id="mcpGatewayAuthMap" type="com.c.infrastructure.dao.po.McpGatewayAuthPO">
        <id property="id" column="id"/>
        <result property="gatewayId" column="gateway_id"/>
        <result property="apiKey" column="api_key"/>
        <result property="rateLimit" column="rate_limit"/>
        <result property="expireTime" column="expire_time"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="all_columns">
        id, gateway_id, api_key, rate_limit, expire_time, status, create_time, update_time
    </sql>

    <insert id="insert" parameterType="com.c.infrastructure.dao.po.McpGatewayAuthPO"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO mcp_gateway_auth (gateway_id, api_key, rate_limit, expire_time, status, create_time, update_time)
        VALUES (#{gatewayId}, #{apiKey}, #{rateLimit}, #{expireTime}, #{status}, NOW(), NOW())
    </insert>

    <delete id="deleteById" parameterType="java.lang.Long">
        DELETE
        FROM mcp_gateway_auth
        WHERE id = #{id}
    </delete>

    <update id="updateById" parameterType="com.c.infrastructure.dao.po.McpGatewayAuthPO">
        UPDATE mcp_gateway_auth
        <set>
            <if test="gatewayId != null">gateway_id = #{gatewayId},</if>
            <if test="apiKey != null">api_key = #{apiKey},</if>
            <if test="rateLimit != null">rate_limit = #{rateLimit},</if>
            <if test="expireTime != null">expire_time = #{expireTime},</if>
            <if test="status != null">status = #{status},</if>
            update_time = NOW()
        </set>
        WHERE id = #{id}
    </update>

    <select id="queryByGatewayId" parameterType="java.lang.String" resultMap="mcpGatewayAuthMap">
        SELECT
        <include refid="all_columns"/>
        FROM mcp_gateway_auth
        WHERE gateway_id = #{gatewayId}
    </select>

    <select id="queryAll" resultMap="mcpGatewayAuthMap">
        SELECT
        <include refid="all_columns"/>
        FROM mcp_gateway_auth
    </select>

</mapper>