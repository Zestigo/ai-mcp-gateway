<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.c.infrastructure.dao.McpProtocolMappingDao">

    <resultMap id="mcpProtocolMappingMap" type="com.c.infrastructure.dao.po.McpProtocolMappingPO">
        <id property="id" column="id"/>
        <result property="protocolId" column="protocol_id"/>
        <result property="mappingType" column="mapping_type"/>
        <result property="parentPath" column="parent_path"/>
        <result property="fieldName" column="field_name"/>
        <result property="mcpPath" column="mcp_path"/>
        <result property="mcpType" column="mcp_type"/>
        <result property="mcpDescription" column="mcp_description"/>
        <result property="isRequired" column="is_required"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="all_columns">
        id, protocol_id, mapping_type, parent_path, field_name,
        mcp_path, mcp_type, mcp_description, is_required,
        sort_order, create_time, update_time
    </sql>

    <insert id="insert" parameterType="com.c.infrastructure.dao.po.McpProtocolMappingPO"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO mcp_protocol_mapping (protocol_id, mapping_type, parent_path, field_name,
                                          mcp_path, mcp_type, mcp_description, is_required,
                                          sort_order, create_time, update_time)
        VALUES (#{protocolId}, #{mappingType}, #{parentPath}, #{fieldName},
                #{mcpPath}, #{mcpType}, #{mcpDescription}, #{isRequired},
                #{sortOrder}, NOW(), NOW())
    </insert>

    <delete id="deleteById">
        DELETE
        FROM mcp_protocol_mapping
        WHERE id = #{id}
    </delete>

    <update id="updateById" parameterType="com.c.infrastructure.dao.po.McpProtocolMappingPO">
        UPDATE mcp_protocol_mapping
        <set>
            <if test="protocolId != null">protocol_id = #{protocolId},</if>
            <if test="mappingType != null">mapping_type = #{mappingType},</if>
            <if test="parentPath != null">parent_path = #{parentPath},</if>
            <if test="fieldName != null">field_name = #{fieldName},</if>
            <if test="mcpPath != null">mcp_path = #{mcpPath},</if>
            <if test="mcpType != null">mcp_type = #{mcpType},</if>
            <if test="mcpDescription != null">mcp_description = #{mcpDescription},</if>
            <if test="isRequired != null">is_required = #{isRequired},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            update_time = NOW()
        </set>
        WHERE id = #{id}
    </update>

    <select id="queryById" resultMap="mcpProtocolMappingMap">
        SELECT
        <include refid="all_columns"/>
        FROM mcp_protocol_mapping
        WHERE id = #{id}
    </select>

    <select id="queryAll" resultMap="mcpProtocolMappingMap">
        SELECT
        <include refid="all_columns"/>
        FROM mcp_protocol_mapping
        ORDER BY sort_order ASC
    </select>

    <select id="queryByProtocolId" resultMap="mcpProtocolMappingMap">
        SELECT
        <include refid="all_columns"/>
        FROM mcp_protocol_mapping
        WHERE protocol_id = #{protocolId}
        ORDER BY sort_order ASC
    </select>

    <select id="queryMcpGatewayToolConfigListByProtocolId" parameterType="java.lang.Long"
            resultMap="mcpProtocolMappingMap">
        SELECT
        <include refid="all_columns"/>
        FROM mcp_protocol_mapping
        WHERE protocol_id = #{protocolId}
        ORDER BY sort_order ASC
    </select>

    <select id="queryByProtocolIds" resultMap="mcpProtocolMappingMap">
        SELECT
        <include refid="all_columns"/>
        FROM mcp_protocol_mapping
        WHERE protocol_id IN
        <foreach collection="protocolIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
        ORDER BY sort_order ASC
    </select>
</mapper>