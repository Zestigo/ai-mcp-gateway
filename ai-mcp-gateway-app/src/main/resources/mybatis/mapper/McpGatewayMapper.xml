<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.c.infrastructure.dao.McpGatewayDao">

    <resultMap id="mcpGatewayMap" type="com.c.infrastructure.dao.po.McpGatewayPO">
        <id property="id" column="id"/>
        <result property="gatewayId" column="gateway_id"/>
        <result property="gatewayName" column="gateway_name"/>
        <result property="gatewayDescription" column="gateway_description"/>
        <result property="gatewayVersion" column="gateway_version"/>
        <result property="status" column="status"/>
        <result property="auth" column="auth"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="all_columns">
        id, gateway_id, gateway_name, gateway_description, gateway_version, status, auth, create_time, update_time
    </sql>

    <insert id="insert" parameterType="com.c.infrastructure.dao.po.McpGatewayPO" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO mcp_gateway (gateway_id, gateway_name, gateway_description,
                                 gateway_version, status, auth, create_time, update_time)
        VALUES (#{gatewayId}, #{gatewayName}, #{gatewayDescription},
                #{gatewayVersion}, #{status}, #{auth}, NOW(), NOW())
    </insert>

    <update id="updateByGatewayId" parameterType="com.c.infrastructure.dao.po.McpGatewayPO">
        UPDATE mcp_gateway
        <set>
            <if test="gatewayName != null">gateway_name = #{gatewayName},</if>
            <if test="gatewayDescription != null">gateway_description = #{gatewayDescription},</if>
            <if test="gatewayVersion != null">gateway_version = #{gatewayVersion},</if>
            <if test="status != null">status = #{status},</if>
            <if test="auth != null">auth = #{auth},</if>
            update_time = NOW()
        </set>
        WHERE gateway_id = #{gatewayId}
    </update>

    <update id="updateAuthStatusByGatewayId" parameterType="com.c.infrastructure.dao.po.McpGatewayPO">
        UPDATE mcp_gateway
        SET auth        = #{auth},
            update_time = NOW()
        WHERE gateway_id = #{gatewayId}
    </update>

    <select id="queryByGatewayId" parameterType="java.lang.String" resultMap="mcpGatewayMap">
        SELECT
        <include refid="all_columns"/>
        FROM mcp_gateway
        WHERE gateway_id = #{gatewayId}
        LIMIT 1
    </select>

    <update id="updateById" parameterType="com.c.infrastructure.dao.po.McpGatewayPO">
        UPDATE mcp_gateway
        <set>
            <if test="gatewayId != null">gateway_id = #{gatewayId},</if>
            <if test="gatewayName != null">gateway_name = #{gatewayName},</if>
            <if test="gatewayDescription != null">gateway_description = #{gatewayDescription},</if>
            <if test="gatewayVersion != null">gateway_version = #{gatewayVersion},</if>
            <if test="status != null">status = #{status},</if>
            <if test="auth != null">auth = #{auth},</if>
            update_time = NOW()
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="java.lang.Long">
        DELETE
        FROM mcp_gateway
        WHERE id = #{id}
    </delete>

    <select id="queryById" parameterType="java.lang.Long" resultMap="mcpGatewayMap">
        SELECT
        <include refid="all_columns"/>
        FROM mcp_gateway WHERE id = #{id}
    </select>

    <select id="queryAll" resultMap="mcpGatewayMap">
        SELECT
        <include refid="all_columns"/>
        FROM mcp_gateway ORDER BY create_time DESC
    </select>

    <select id="countAll" resultType="java.lang.Long">
        SELECT COUNT(*)
        FROM mcp_gateway
    </select>

    <select id="queryByGatewayIds" resultMap="mcpGatewayMap">
        SELECT
        <include refid="all_columns"/>
        FROM mcp_gateway
        WHERE gateway_id IN
        <foreach collection="gatewayIds" item="gid" open="(" separator="," close=")">
            #{gid}
        </foreach>
    </select>

    <select id="queryActiveGateways" resultMap="mcpGatewayMap">
        SELECT
        <include refid="all_columns"/>
        FROM mcp_gateway
        WHERE status = 1
        ORDER BY update_time DESC
    </select>

</mapper>