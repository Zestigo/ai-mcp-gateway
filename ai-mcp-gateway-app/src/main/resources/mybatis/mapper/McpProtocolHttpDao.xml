<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.c.infrastructure.dao.McpProtocolHttpDao">

    <resultMap id="McpProtocolRegistryMap" type="com.c.infrastructure.dao.po.McpProtocolHttpPO">
        <id column="id" property="id"/>
        <result column="protocol_id" property="protocolId"/>
        <result column="http_url" property="httpUrl"/>
        <result column="http_method" property="httpMethod"/>
        <result column="http_headers" property="httpHeaders"/>
        <result column="timeout" property="timeout"/>
        <result column="retry_times" property="retryTimes"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, protocol_id, http_url, http_method, http_headers, timeout, retry_times, status, create_time, update_time
    </sql>

    <insert id="insert" parameterType="com.c.infrastructure.dao.po.McpProtocolHttpPO" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO mcp_protocol_http (protocol_id, http_url, http_method, http_headers, timeout, retry_times, status, create_time, update_time)
        VALUES (#{protocolId}, #{httpUrl}, #{httpMethod}, #{httpHeaders}, #{timeout}, #{retryTimes}, #{status}, NOW(), NOW())
    </insert>

    <insert id="insertList" parameterType="java.util.List">
        INSERT INTO mcp_protocol_http (protocol_id, http_url, http_method, http_headers, timeout, retry_times, status, create_time, update_time)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.protocolId}, #{item.httpUrl}, #{item.httpMethod}, #{item.httpHeaders}, #{item.timeout}, #{item.retryTimes}, #{item.status}, NOW(),
            NOW())
        </foreach>
    </insert>

    <delete id="deleteById" parameterType="java.lang.Long">
        DELETE
        FROM mcp_protocol_http
        WHERE id = #{id}
    </delete>

    <delete id="deleteByProtocolId" parameterType="java.lang.Long">
        DELETE
        FROM mcp_protocol_http
        WHERE protocol_id = #{protocolId}
    </delete>

    <update id="updateById" parameterType="com.c.infrastructure.dao.po.McpProtocolHttpPO">
        UPDATE mcp_protocol_http
        SET protocol_id  = #{protocolId},
            http_url     = #{httpUrl},
            http_method  = #{httpMethod},
            http_headers = #{httpHeaders},
            timeout      = #{timeout},
            retry_times  = #{retryTimes},
            status       = #{status},
            update_time  = NOW()
        WHERE id = #{id}
    </update>

    <update id="updateStatus">
        UPDATE mcp_protocol_http
        SET status      = #{status},
            update_time = NOW()
        WHERE protocol_id = #{protocolId}
    </update>

    <select id="queryById" parameterType="java.lang.Long" resultMap="McpProtocolRegistryMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM mcp_protocol_http
        WHERE id = #{id}
    </select>

    <select id="queryAll" resultMap="McpProtocolRegistryMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM mcp_protocol_http
        ORDER BY id DESC
    </select>

    <select id="queryByProtocolId" parameterType="java.lang.Long" resultMap="McpProtocolRegistryMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM mcp_protocol_http
        WHERE protocol_id = #{protocolId}
    </select>

    <select id="queryMcpProtocolHttpByProtocolId" parameterType="java.lang.Long" resultMap="McpProtocolRegistryMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM mcp_protocol_http
        WHERE protocol_id = #{protocolId}
    </select>

    <select id="queryByUrlAndMethod" resultMap="McpProtocolRegistryMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM mcp_protocol_http
        WHERE http_url = #{httpUrl} AND http_method = #{httpMethod}
        LIMIT 1
    </select>

    <select id="queryProtocolPage" resultMap="McpProtocolRegistryMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM mcp_protocol_http
        <where>
            <if test="urlKeyword != null and urlKeyword != ''">
                AND http_url LIKE CONCAT('%', #{urlKeyword}, '%')
            </if>
        </where>
        ORDER BY create_time DESC
        LIMIT #{offset}, #{limit}
    </select>

    <select id="queryAllActive" resultMap="McpProtocolRegistryMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM mcp_protocol_http
        WHERE status = 1
        ORDER BY id DESC
    </select>
</mapper>