<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.c.infrastructure.dao.McpProtocolRegistryDao">

    <resultMap id="mcpProtocolRegistryMap" type="com.c.infrastructure.dao.po.McpProtocolRegistryPO">
        <id property="id" column="id"/>
        <result property="gatewayId" column="gateway_id"/>
        <result property="toolId" column="tool_id"/>
        <result property="toolName" column="tool_name"/>
        <result property="toolType" column="tool_type"/>
        <result property="toolDescription" column="tool_description"/>
        <result property="toolVersion" column="tool_version"/>
        <result property="httpUrl" column="http_url"/>
        <result property="httpMethod" column="http_method"/>
        <result property="httpHeaders" column="http_headers"/>
        <result property="timeout" column="timeout"/>
        <result property="retryTimes" column="retry_times"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="all_columns">
        id, gateway_id, tool_id, tool_name, tool_type, tool_description, tool_version,
        http_url, http_method, http_headers, timeout, retry_times, status, create_time, update_time
    </sql>

    <insert id="insert" parameterType="com.c.infrastructure.dao.po.McpProtocolRegistryPO" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO mcp_protocol_registry (gateway_id, tool_id, tool_name, tool_type, tool_description, tool_version,
                                           http_url, http_method, http_headers, timeout, retry_times, status, create_time, update_time)
        VALUES (#{gatewayId}, #{toolId}, #{toolName}, #{toolType}, #{toolDescription}, #{toolVersion},
                #{httpUrl}, #{httpMethod}, #{httpHeaders}, #{timeout}, #{retryTimes}, #{status}, NOW(), NOW())
    </insert>

    <delete id="deleteById" parameterType="java.lang.Long">
        DELETE
        FROM mcp_protocol_registry
        WHERE id = #{id}
    </delete>

    <update id="updateById" parameterType="com.c.infrastructure.dao.po.McpProtocolRegistryPO">
        UPDATE mcp_protocol_registry
        <set>
            <if test="gatewayId != null">gateway_id = #{gatewayId},</if>
            <if test="toolName != null">tool_name = #{toolName},</if>
            <if test="toolDescription != null">tool_description = #{toolDescription},</if>
            <if test="httpUrl != null">http_url = #{httpUrl},</if>
            <if test="status != null">status = #{status},</if>
            update_time = NOW()
        </set>
        WHERE id = #{id}
    </update>

    <select id="queryById" parameterType="java.lang.Long" resultMap="mcpProtocolRegistryMap">
        SELECT
        <include refid="all_columns"/>
        FROM mcp_protocol_registry WHERE id = #{id}
    </select>

    <select id="queryAll" resultMap="mcpProtocolRegistryMap">
        SELECT
        <include refid="all_columns"/>
        FROM mcp_protocol_registry
    </select>

    <select id="queryMcpProtocolRegistryByGatewayId" parameterType="java.lang.String" resultMap="mcpProtocolRegistryMap">
        SELECT
        <include refid="all_columns"/>
        FROM mcp_protocol_registry
        WHERE gateway_id = #{gatewayId} AND status = 1
    </select>

</mapper>